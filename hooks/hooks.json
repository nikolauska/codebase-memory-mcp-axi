{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "cbm-axi",
            "commandWindows": "cbm-axi",
            "timeout": 30,
            "statusMessage": "Loading cbm-axi context..."
          }
        ]
      }
    ]
  }
}
